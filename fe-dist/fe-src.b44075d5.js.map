                errorMessage.style.display = 'block';
                return;
            }
            if (password.length < 8) {
                errorMessage.textContent = "La contrase\xf1a debe tener al menos 8 caracteres";
                errorMessage.style.display = 'block';
                return;
            }
            // Construir objeto de ubicación solo si se obtuvo
            const location = this.userLat && this.userLng ? {
